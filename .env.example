# MedMitra RAG Backend Configuration

# Security
INTERNAL_API_KEY=replace_with_secure_key

# Qdrant Database (Local mode is fallback if URL/Key are empty)
QDRANT_URL=
QDRANT_API_KEY=
QDRANT_COLLECTION=medical_books

# LLM Config (Groq Llama 3)
GROQ_API_KEY=
LLAMA_MODEL=llama-3.3-70b-versatile

# Retrieval Embeddings Models
DENSE_MODEL_NAME=BAAI/bge-small-en-v1.5
SPARSE_MODEL_NAME=prithivida/Splade_PP_en_v1

# Search thresholds
DENSE_PREFETCH_K=20
SPARSE_PREFETCH_K=20
FINAL_TOP_K=5

# Document Ingestion parameters
CHUNK_SIZE=1800
CHUNK_OVERLAP=250
INGEST_BATCH_SIZE=15

# Generation parameters
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=600
LLM_TIMEOUT_SECONDS=30

# Logging
LOG_LEVEL=INFO
QDRANT_TIMEOUT_SECONDS=120
DENSE_VECTOR_SIZE=384


INGEST_BATCH_SIZE=5
INGEST_MAX_RETRIES=10
INGEST_RETRY_BASE_SECONDS=3

HNSW_M=16
