APP_NAME=medmitra-ml-search
APP_ENV=development
API_V1_PREFIX=/api/v1

# ─── Authentication ────────────────────────────────────────────────
# Generate a strong key: python -c "import secrets; print(secrets.token_hex(32))"
INTERNAL_API_KEY=medmitra_internal_secure_key_123

# ─── Qdrant Vector Store ───────────────────────────────────────────
# Docker local: docker run -p 6333:6333 -p 6334:6334 qdrant/qdrant
# Windows PowerShell:
#   docker run -p 6333:6333 -p 6334:6334 -v "${PWD}/qdrant_storage:/qdrant/storage:z" qdrant/qdrant
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=medmitra_knowledge
QDRANT_COLLECTION_PREFIX=medmitra_knowledge
QDRANT_COLLECTION_ALIAS=medmitra_knowledge_current
QDRANT_HOST_PORT=6333

# ─── MedCPT Encoders ──────────────────────────────────────────────
MEDCPT_QUERY_MODEL=ncbi/MedCPT-Query-Encoder
MEDCPT_ARTICLE_MODEL=ncbi/MedCPT-Article-Encoder
EMBEDDING_DEVICE=cpu
DENSE_VECTOR_SIZE=768
EMBEDDING_BATCH_SIZE=16
HF_TOKEN=

# ─── Retrieval Configuration ───────────────────────────────────────
DENSE_TOP_K=15
SPARSE_TOP_K=15
FINAL_TOP_K=5
RRF_K=60
RETRIEVAL_DENSE_PREFETCH_K=18
RETRIEVAL_SPARSE_PREFETCH_K=18
RETRIEVAL_FINAL_K=4
RETRIEVAL_MIN_RELEVANCE=0.30
DISEASE_SEARCH_MIN_RELEVANCE=0.10
MEDICINE_SEARCH_MIN_RELEVANCE=0.10

# ─── LLM (Groq — free tier, OpenAI-compatible) ────────────────────
# Get your free Groq key at: https://console.groq.com/
# Supported model: llama-3.3-70b-versatile (or llama-3.1-8b-instant for faster responses)
LLM_PROVIDER=groq
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_MODEL=llama-3.3-70b-versatile
GROQ_API_KEY=
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=500
LLM_TIMEOUT_SECONDS=30

# ─── Feature Flags ────────────────────────────────────────────────
LLM_ENABLED=true
AGENT_ENABLED=true
USE_DEMO_SEED_DATA=true

# ─── Chunking (book ingestion — optional future use) ──────────────
CHUNK_TARGET_TOKENS=260
CHUNK_MIN_TOKENS=70
CHUNK_MAX_TOKENS=360
CHUNK_OVERLAP_TOKENS=45

# ─── Kaggle (for dataset download) ───────────────────────────────
# Get your credentials at: https://www.kaggle.com/settings → API
KAGGLE_USERNAME=
KAGGLE_KEY=

# ─── General ──────────────────────────────────────────────────────
MAX_UPLOAD_MB=10
LOG_LEVEL=INFO
EMBEDDING_MODEL=NeuML/pubmedbert-base-embeddings
